# Production environment template. Copy to .env on the server and fill in.
# Generate a secret key, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"

DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=cms.example.com
CSRF_TRUSTED_ORIGINS=https://cms.example.com

# Database (PostgreSQL)
DB_ENGINE=postgres
DB_NAME=cms
DB_USER=cms
DB_PASSWORD=replace-with-a-strong-password
DB_HOST=localhost
DB_PORT=5432

# Static files: enable hashed/compressed assets (run collectstatic first)
STATIC_MANIFEST=True

# HTTPS / security hardening (enable once TLS is in place)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Set to True when running behind a TLS-terminating reverse proxy (nginx, etc.)
USE_PROXY_SSL_HEADER=True
