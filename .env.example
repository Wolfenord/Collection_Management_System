# Copy to .env and adjust. The app runs on SQLite by default and switches to
# PostgreSQL when DB_ENGINE=postgres (no code changes required).
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

DB_ENGINE=postgres
DB_NAME=cms
DB_USER=cms
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432

# Logging: one rotating file per day in LOG_DIR (default: <project>/logs).
# LOG_LEVEL: DEBUG | INFO (default) | WARNING | ERROR.
# LOG_RETENTION_DAYS: how many past daily files to keep (default 30).
# LOG_DIR=/var/log/cms
# LOG_LEVEL=INFO
# LOG_RETENTION_DAYS=30
