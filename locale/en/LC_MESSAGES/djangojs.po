#: static/js/capture.js:32
msgid "Mit Kamera aufnehmen"
msgstr "Take a photo with the camera"

#: static/js/capture.js:51 static/js/scanner.js:81
msgid "Kamera nicht verfügbar:"
msgstr "Camera not available:"

#: static/js/capture.js:53
msgid "du kannst stattdessen eine Datei auswählen."
