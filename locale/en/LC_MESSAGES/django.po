#: Collection_Management_System/lookup_providers.py:541
msgid ""
"Offene, kostenlose Bücher-Datenbank des Internet Archive. Suche per ISBN."
msgstr "Open, free book database by the Internet Archive. Lookup by ISBN."

#: Collection_Management_System/lookup_providers.py:551
msgid "Google Books (Bücher · ISBN)"
msgstr "Google Books (books · ISBN)"

#: Collection_Management_System/lookup_providers.py:553
msgid ""
"Google-Buchsuche. Suche per ISBN, liefert zusätzlich Beschreibung & Sprache."
msgstr ""
"Google book search. Lookup by ISBN, additionally returns description & "
"language."

#: Collection_Management_System/lookup_providers.py:564
msgid "Deutsche Nationalbibliothek (Bücher · ISBN)"
msgstr "German National Library / DNB (books · ISBN)"

#: Collection_Management_System/lookup_providers.py:566
msgid ""
"Offizieller DNB-Katalog – beste Abdeckung für deutschsprachige Bücher. Suche "
"per ISBN."
msgstr ""
"Official DNB catalogue – best coverage for German-language books. Search by "
"ISBN."

#: Collection_Management_System/lookup_providers.py:636
msgid "MusicBrainz (Musik · Barcode)"
msgstr "MusicBrainz (music · barcode)"

#: Collection_Management_System/lookup_providers.py:638
msgid ""
"Offene Musik-Datenbank: CDs, Vinyl & Co. per Barcode-Scan oder Titel-/"
"Interpretensuche."
msgstr "Open music database: CDs, vinyl & co. via barcode scan or title/artist search."

#: Collection_Management_System/lookup_providers.py:709
msgid "TMDb (Filme & Serien · Titelsuche)"
msgstr "TMDb (films & series · title search)"

#: Collection_Management_System/lookup_providers.py:711
msgid ""
"The Movie Database: Filme & Serien per Titelsuche. Benötigt einen "
"kostenlosen API-Schlüssel (Systemeinstellungen → TMDb-API-Schlüssel)."
msgstr "The Movie Database: films & series via title search. Requires a free API key (system settings → TMDb API key)."

#: Collection_Management_System/lookup_providers.py:762
msgid "RAWG (Videospiele · Titelsuche)"
msgstr "RAWG (video games · title search)"

#: Collection_Management_System/lookup_providers.py:764
msgid ""
"Größte offene Videospiel-Datenbank: Titelsuche mit Plattformen & Genres. "
"Benötigt einen kostenlosen API-Schlüssel (Systemeinstellungen → RAWG-API-"
"Schlüssel)."
msgstr "Largest open video-game database: title search with platforms & genres. Requires a free API key (system settings → RAWG API key)."

#: Collection_Management_System/lookup_providers.py:874
msgid "Wikidata (Brett- & Gesellschaftsspiele · Titelsuche)"
msgstr "Wikidata (board games · title search)"

#: Collection_Management_System/lookup_providers.py:876
msgid ""
"Freie Wissensdatenbank: Titelsuche für Brett-, Karten- und "
"Gesellschaftsspiele mit Jahr, Spielerzahl und Bild."
msgstr ""
"Free knowledge base: title search for board, card and party games with year, "
"player count and image."

#: Collection_Management_System/lookup_providers.py:916
msgid "UPCitemdb (Alle Produkte · Barcode)"
msgstr "UPCitemdb (all products · barcode)"

#: Collection_Management_System/lookup_providers.py:918
msgid ""
"Generische Produktdatenbank: liefert zu fast jedem EAN/UPC-Barcode Titel, "
"Marke und Kategorie (kostenloses Kontingent, ohne Schlüssel)."
msgstr "Generic product database: returns title, brand and category for almost any EAN/UPC barcode (free quota, no key)."

#: Collection_Management_System/lookup_providers.py:1029
msgid "keine Datenbank verfügbar"
msgstr "no database available"

